#!/usr/bin/env python3
"""
PortShim CLI Wrapper — one-command engagement start + server lifecycle.

Usage:
    portshim scan 10.0.0.0/22                          # Default: surgical + hybrid
    portshim scan 10.0.0.0/22 --engagement silent-entry   # Quiet mode
    portshim scan 10.0.0.0/22 --dry-run                 # Preview only
    portshim server start [--model <id>]                 # Start llama-server
    portshim server stop                                # Stop llama-server
    portshim server status                              # Check server status
    portshim server restart [--model <id>]              # Restart with model
    portshim server models                              # List available models

    portshim wireless scan                             # Discover nearby APs
    portshim wireless scan --duration 30 --band 5       # 30s, 5 GHz only
    portshim wireless select                           # Pick APs to assess
    portshim wireless assess                           # Test selected APs
    portshim wireless capture                          # Capture WPA handshakes
    portshim wireless crack --cap <file>               # Crack WPA handshakes
    portshim wireless deauth                           # Deauthenticate clients

    portshim --help                                    # Show all commands

Environment:
    PD_MODELS_DIR    Path to .gguf model files (default: ~/local-models)
"""

import argparse, json, os, signal, subprocess, sys, textwrap, time
