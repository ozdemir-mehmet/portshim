SCRIPTS = PROJECT_ROOT / "scripts"
SKILL_SCRIPTS = PROJECT_ROOT / "skills" / "site-assessment-pipeline" / "scripts"
PID_FILE = Path(os.path.expanduser("~/.hermes")) / "llama-server.pid"

