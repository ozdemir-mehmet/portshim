    },
    "supergemma4-26b-uncensored": {
        "path": "supergemma4-26b-uncensored",
        "file": "supergemma4-26b-uncensored-fast-v2-Q4_K_M.gguf",
    },
    "hauhau-cs-35b-uncensored": {
