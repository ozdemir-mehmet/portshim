# ── Colour helpers ──
RED = "\033[91m"
GREEN = "\033[92m"
CYAN = "\033[96m"
YELLOW = "\033[93m"
BOLD = "\033[1m"
RESET = "\033[0m"


def status(msg, ok=True):
    symbol = f"{GREEN}✓{RESET}" if ok else f"{RED}✗{RESET}"
    print(f"  {symbol} {msg}")


def header(msg):
    print(f"\n{BOLD}{CYAN}═══ {msg} {RESET}{'═' * (60 - len(msg))}")


def warn(msg):
    print(f"  {YELLOW}⚠ {msg}{RESET}")


def _local_subnets():
    """Return list of local subnets from 'ip -4 addr show'."""
    import ipaddress
    try:
        result = subprocess.run(
            ["ip", "-4", "-o", "addr", "show"],
            capture_output=True, text=True, timeout=10,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return []

    subnets = []
    for line in result.stdout.strip().split("\n"):
        parts = line.split()
        for part in parts:
            if "/" in part:
                try:
                    subnets.append(ipaddress.IPv4Network(part, strict=False))
                except ValueError:
                    pass
    return subnets


def verify_target_subnet(target: str) -> bool:
    """Check target CIDR overlaps with a local subnet. Returns True if reachable."""
    import ipaddress
    try:
        target_net = ipaddress.IPv4Network(target, strict=False)
    except ValueError:
        warn(f"Cannot parse target CIDR: {target}")
        return False

    local_nets = _local_subnets()
    if not local_nets:
        # Can't determine local subnets — skip check
        return True

    for local_net in local_nets:
        if target_net.overlaps(local_net):
            return True

    local_str = ", ".join(str(n) for n in local_nets)
    warn(f"Target {target} does not overlap any local subnet ({local_str})")
    print(f"  nmap may fail to reach any hosts on {target}.")
    return False


def _models_dir():
    """Resolve the models directory."""
    env = os.environ.get("PD_MODELS_DIR")
    if env:
        return Path(env)
    return Path.home() / "local-models"


def _model_path(model_id):
    """Resolve full GGUF path for a model ID. Returns None if not found."""
    info = MODEL_IDS.get(model_id)
    if not info:
        return None
    path = _models_dir() / info["path"] / info["file"]
    return path if path.exists() else None


def _find_llama_server():
    """Locate llama-server binary."""
    # Check PATH first
    for bin_path in ["llama-server"]:
        r = subprocess.run(["which", bin_path], capture_output=True, text=True, timeout=5)
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip()
    # Check common locations
    for candidate in [
        Path.home() / ".local" / "bin" / "llama-server",
        Path("/usr/local/bin/llama-server"),
        Path("/usr/bin/llama-server"),
    ]:
        if candidate.exists():
            return str(candidate)
    return None


# ── Server lifecycle ──

def server_running():
    """Check if a llama-server process is running (by PID file)."""
    if not PID_FILE.exists():
        return False
    try:
        pid = int(PID_FILE.read_text().strip().split()[0])
        os.kill(pid, 0)  # Check if alive
        return True
    except (OSError, ValueError, IndexError):
        PID_FILE.unlink(missing_ok=True)
        return False


def server_get_model():
    """Get the model ID the running server is serving (from PID file)."""
    if not PID_FILE.exists():
        return None
    try:
        parts = PID_FILE.read_text().strip().split(maxsplit=1)
        if len(parts) > 1:
            return parts[1]
        return None
    except OSError:
        return None


def server_stop():
    """Stop the running llama-server."""
    header("Server Stop")
    if not PID_FILE.exists():
        warn("No server PID file found. Nothing to stop.")
        return True

    try:
        pid = int(PID_FILE.read_text().strip().split()[0])
        os.kill(pid, signal.SIGTERM)

        # Wait up to 5 seconds for graceful shutdown
        for _ in range(10):
            try:
                os.kill(pid, 0)
                time.sleep(0.5)
            except OSError:
                break
        else:
            # Force kill
            try:
                os.kill(pid, signal.SIGKILL)
            except OSError:
                pass

        PID_FILE.unlink(missing_ok=True)
        status(f"Server stopped (PID {pid})", True)
        return True
    except (OSError, ValueError, IndexError) as e:
        warn(f"Could not stop server: {e}")
        PID_FILE.unlink(missing_ok=True)
        return False


def server_start(model_id=None, port=8080, host="127.0.0.1", ngl=-1):
    """Start llama-server with the specified model."""
    header("Server Start")

    # If already running, offer restart
    if server_running():
        current = server_get_model()
        warn(f"Server already running (model: {current or 'unknown'})")
        print(f"  Use '{BOLD}portshim server restart{RESET}' to switch models")
        return False

    # Resolve model
    if not model_id:
        model_id = PHASE_DEFAULTS["recon"]
        warn(f"No model specified. Using default for Phase 1: {model_id}")

    gguf_path = _model_path(model_id)
    if not gguf_path:
        available = [m for m in MODEL_IDS if _model_path(m)]
        print(f"  {RED}Model '{model_id}' not found in:{RESET}")
        print(f"    {_models_dir()}")
        print(f"\n  Available models:")
        for m in available:
            p = _model_path(m)
            print(f"    • {m}  ({p.parent.name}/{p.name})")
        print(f"\n  Tip: Set {BOLD}PD_MODELS_DIR{RESET} if models are elsewhere")
        return False

    llama_bin = _find_llama_server()
    if not llama_bin:
        print(f"  {RED}llama-server not found in PATH or common locations.{RESET}")
        print(f"  Install via: pacman -S llama.cpp, or build from source.")
        return False

    size_gb = gguf_path.stat().st_size / (1024**3)
    print(f"  Model:   {model_id}")
    print(f"  File:    {gguf_path}")
    print(f"  Size:    {size_gb:.1f} GiB")
    print(f"  Port:    {host}:{port}")
    print(f"  GPU:     {'Vulkan (all layers)' if ngl < 0 else f'{ngl} layers'}")
    print()

    cmd = [
        llama_bin,
        "-m", str(gguf_path),
        "--host", host,
        "--port", str(port),
        "-ngl", str(ngl),
        "-c", "16384",  # Context size
        "--no-warmup",  # Skip warmup for faster start
    ]

    log_path = PROJECT_ROOT / "logs" / "llama-server.log"
    log_path.parent.mkdir(parents=True, exist_ok=True)

    try:
        proc = subprocess.Popen(
            cmd,
            stdout=open(log_path, "w"),
            stderr=subprocess.STDOUT,
            preexec_fn=os.setsid,  # Process group for clean kill
        )
    except FileNotFoundError:
        print(f"  {RED}Failed to execute: {llama_bin}{RESET}")
        return False

    # Write PID + model info
    PID_FILE.parent.mkdir(parents=True, exist_ok=True)
    PID_FILE.write_text(f"{proc.pid} {model_id}\n")

    # Wait for server to be ready (check health endpoint)
    print(f"  Waiting for server to start... ", end="", flush=True)
    for _ in range(30):  # 30 seconds max
        time.sleep(1)
        try:
            r = subprocess.run(
                ["curl", "-s", "-o", "/dev/null", "-w", "%{http_code}",
                 f"http://{host}:{port}/health"],
                capture_output=True, text=True, timeout=3,
            )
            if r.stdout.strip() == "200":
                print(f"{GREEN}ready{RESET}")
                status(f"Server started (PID {proc.pid})", True)
                status(f"Endpoint: http://{host}:{port}/v1", True)
                status(f"Logs: {log_path}", True)
                return True
        except (subprocess.TimeoutExpired, OSError):
            pass
        print(".", end="", flush=True)

    print(f"\n  {YELLOW}Server process started but health check timed out.{RESET}")
    status(f"Check logs: {log_path}", False)
    return True


# ── Scan flow ──

def run(cmd, check=True):
    """Run a command, return success."""
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=120)
        return result.returncode == 0
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return False


def check_prerequisites():
    """Verify the environment is ready."""
    header("Prerequisites")
    all_ok = True

    # Python deps
    for module in ["docx", "openpyxl"]:
        try:
            __import__(module)
            status(f"Python: {module}", True)
        except ImportError:
            status(f"Python: {module} (missing — run: pip install python-docx openpyxl)", False)
            all_ok = False

    # Tools (loose check — deploy.py should have installed these)
    tools = {
        "nmap": "nmap --version",
        "nuclei": "nuclei -version",
        "httpx": "httpx -version",
    }
    for tool, check_cmd in tools.items():
        ok = run(check_cmd.split(), check=False)
        status(f"Tool: {tool}", ok)
        if not ok:
            all_ok = False

    # Hermes
    ok = run(["hermes", "--version"], check=False)
    status("Hermes Agent", ok)
    if not ok:
        all_ok = False

    # Project scripts
    for script, path in [
        ("sync_knowledge.py", SCRIPTS / "sync_knowledge.py"),
        ("check-skill-freshness.py", SCRIPTS / "check-skill-freshness.py"),
        ("engagement-profiles.py", SKILL_SCRIPTS / "engagement-profiles.py"),
        ("llm-config.py", SKILL_SCRIPTS / "llm-config.py"),
    ]:
        ok = path.exists()
        status(f"Script: {script}", ok)
        if not ok:
            all_ok = False

    # llama.cpp
    llama_bin = _find_llama_server()
    status(f"Tool: llama-server ({llama_bin or 'not found'})", bool(llama_bin))
    if not llama_bin:
        all_ok = False

    return all_ok


def sync_knowledge():
    """Pull latest from tracked repos."""
    header("Sync Knowledge")
    print("  Pulling latest CVE data, exploit signatures, and skill updates...")
    ok = run([sys.executable, str(SCRIPTS / "sync_knowledge.py"), "--all"])
    status("Knowledge synced", ok)
    return ok


def check_freshness():
    """Check if tracked repos are stale."""
    header("Freshness Check")
    script = SCRIPTS / "check-skill-freshness.py"
    result = subprocess.run(
        [sys.executable, str(script)],
        capture_output=True, text=True,
    )
    stale = "stale" in result.stdout.lower() or "STALE" in result.stdout
    if result.returncode != 0:
        status("Freshness check failed — continuing anyway", False)
        return True  # Non-blocking
    if stale:
        status("Some tracked repos are stale (>30 days). Consider updating.", False)
    else:
        status("All tracked repos current", True)
    return True


def configure_engagement(profile="surgical"):
    """Set the engagement noise profile (quietest → loudest)."""
    header("Engagement Profile")
    valid = ["silent-entry", "surgical", "full-assault"]
    if profile not in valid:
        print(f"  {RED}Invalid profile: {profile}. Must be one of: {', '.join(valid)}{RESET}")
        return False
    ok = run([sys.executable, str(SKILL_SCRIPTS / "engagement-profiles.py"), profile])
    if ok:
        label = {
            "silent-entry": "Silent Entry (IDS-aware)",
            "surgical": "Surgical (balanced)",
            "full-assault": "Full Assault (maximum speed)",
        }
        status(label.get(profile, profile), True)
    else:
        status(f"Failed to set {profile}", False)
    return ok


def configure_llm(mode="hybrid", models_dir=None):
    """Configure LLM deployment mode."""
    header("LLM Configuration")
    valid = ["local", "hybrid", "cloud"]
    if mode not in valid:
        print(f"  {RED}Invalid mode: {mode}. Must be one of: {', '.join(valid)}{RESET}")
        return False

    label = {
        "local": "Fully Local (air-gap)",
        "hybrid": "Hybrid (local exploit, cloud report)",
        "cloud": "Fully Cloud (API)",
    }

    # Set models dir env if provided
    env = os.environ.copy()
    if models_dir:
        env["PD_MODELS_DIR"] = models_dir
        status(f"Models directory: {models_dir}", True)
    else:
        default_models = os.environ.get(
            "PD_MODELS_DIR", os.path.join(os.path.expanduser("~"), "local-models")
        )
        status(f"Models directory: {default_models} (default)", True)

    ok = run(
        [sys.executable, str(SKILL_SCRIPTS / "llm-config.py"), mode, "--output-dir", str(PROJECT_ROOT / "configs")]
    )
    if ok:
        status(label.get(mode, mode), True)
    else:
        status(f"Failed to configure {mode}", False)
    return ok


