# ── Server subcommand handlers ──

def cmd_server_start(args):
    server_start(
        model_id=args.model,
        port=args.port,
        host=args.host,
        ngl=-1 if args.offload_all else args.ngl,
    )


def cmd_server_stop(args=None):
    return server_stop()


def cmd_server_restart(args):
    server_stop()
    print()
    server_start(
        model_id=args.model,
        port=args.port,
        host=args.host,
        ngl=-1 if args.offload_all else args.ngl,
    )


def cmd_server_status(args=None):
    header("Server Status")
    if server_running():
        model = server_get_model()
        print(f"  {GREEN}● Running{RESET}")
        print(f"  Model: {model or 'unknown'}")
        print(f"  PID:   {PID_FILE.read_text().strip().split()[0]}")
        print(f"  Port:  127.0.0.1:8080")
    else:
        print(f"  ○ Stopped")
    return True


def cmd_server_models(args=None):
    header("Available Models")
    any_found = False
    for mid, info in MODEL_IDS.items():
        gguf_path = _models_dir() / info["path"] / info["file"]
        if gguf_path.exists():
            size = gguf_path.stat().st_size / (1024**3)
            print(f"  {GREEN}✔{RESET} {mid}")
            print(f"      {gguf_path.name}  ({size:.1f} GiB)")
            any_found = True
        else:
            print(f"  {YELLOW}✗{RESET} {mid}")
            print(f"      NOT FOUND at {gguf_path}")
    if not any_found:
        print(f"  {YELLOW}No models found. Set PD_MODELS_DIR or download models.{RESET}")
    return True


# ── Main ──

def main():
    parser = argparse.ArgumentParser(
        description="PortShim — one-command engagement start",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            Examples:
              portshim scan 10.0.0.0/22
              portshim scan 10.0.0.0/22 --stealth silent-entry --mode local
              portshim scan 10.0.0.0/22 --dry-run
              portshim scan 10.0.0.0/22 --no-freshness-check

              portshim wireless scan
              portshim wireless scan --duration 30 --band 5
              portshim wireless select
              portshim wireless assess
              portshim wireless capture
              portshim wireless crack --cap <file>
              portshim wireless deauth

              portshim server start --model qwen3-coder-30b-a3b-instruct
              portshim server start --model supergemma4-26b-uncensored
              portshim server stop
              portshim server status
              portshim server models
        """),
    )
    subparsers = parser.add_subparsers(dest="command", help="Commands")

    # ── scan ──
    scan = subparsers.add_parser("scan", help="Start a new engagement")
    scan.add_argument("target", help="Target IP range (CIDR, e.g. 10.0.0.0/22)")
    scan.add_argument(
        "--engagement",
        default="surgical",
        choices=["silent-entry", "surgical", "full-assault"],
        help="Engagement profile (quietest→loudest). Default: surgical",
    )
    scan.add_argument(
        "--mode",
        default="hybrid",
        choices=["local", "hybrid", "cloud"],
        help="LLM deployment mode (default: hybrid)",
    )
    scan.add_argument(
        "--no-freshness-check", action="store_true", help="Skip repository freshness check"
    )
    scan.add_argument(
        "--models-dir",
        default=os.environ.get("PD_MODELS_DIR"),
        help="Path to .gguf model files (env: PD_MODELS_DIR)",
    )
    scan.add_argument(
        "--dry-run", action="store_true", help="Preview without executing"
    )
    scan.add_argument(
        "--no-server", action="store_true",
        help="Don't auto-start llama-server (for local/hybrid modes)",
    )
    scan.add_argument(
        "--wireless", action="store_true",
        help=argparse.SUPPRESS,  # Hidden — deprecated
    )

    # ── wireless ──
    wireless = subparsers.add_parser("wireless", help="Wireless RF assessment")
    wireless_sub = wireless.add_subparsers(dest="wireless_action")

    w_scan = wireless_sub.add_parser("scan", help="Discover nearby access points")
    w_scan.add_argument("--duration", type=int, default=15,
                        help="Scan duration in seconds (default: 15)")
    w_scan.add_argument("--band", choices=["2.4", "5", "both"], default="both",
                        help="Frequency band (default: both)")
    w_scan.add_argument("--interface", default=None,
                        help="Wireless interface (auto-detect if not specified)")
    w_scan.add_argument("--dry-run", action="store_true",
                        help="Detect hardware without scanning")
    w_scan.add_argument("--force", action="store_true",
                        help="Skip interactive prompts (agent-friendly)")
    w_scan.add_argument("--models-dir",
                        default=os.environ.get("PD_MODELS_DIR"),
                        help=argparse.SUPPRESS)

    w_select = wireless_sub.add_parser("select",
                                       help="Select APs from discovered list")
    w_select.add_argument("--file", default=None,
                          help="Load targets from JSON file")
    w_select.add_argument("--scan-file", default=None,
                          help="Use a specific scan output (default: most recent)")

    w_assess = wireless_sub.add_parser("assess",
                                       help="Run active assessment on selected APs")
    w_assess.add_argument("--targets-file", default=None,
                          help="Target selection JSON file (default: most recent)")
    w_assess.add_argument("--file", default=None,
                          help="Alias for --targets-file")
    w_assess.add_argument("--interface", default=None,
                          help="Wireless interface (auto-detect if not specified)")
    w_assess.add_argument("--no-scan", action="store_true",
                          help="Skip fresh scan, use cached data only")

    w_capture = wireless_sub.add_parser("capture",
                                        help="Capture WPA handshakes from selected targets")
    w_capture.add_argument("--targets-file", "--file", default=None,
                           help="Target selection JSON file (default: most recent)")
    w_capture.add_argument("--interface", default=None,
                           help="Wireless interface (auto-detect if not specified)")
    w_capture.add_argument("--duration", type=int, default=60,
                           help="Capture duration in seconds (default: 60)")
    w_capture.add_argument("--dry-run", action="store_true",
                           help="Show capture plan without capturing")
    w_capture.add_argument("--force", action="store_true",
                           help="Skip prompts and proceed with monitor mode")

    w_crack = wireless_sub.add_parser("crack",
                                      help="Crack captured WPA handshakes")
    w_crack.add_argument("--cap", required=True,
                         help="Capture file (.cap/.pcapng) with WPA handshake")
    w_crack.add_argument("--wordlist", default=None,
                         help="Wordlist file (default: system wordlist)")
    w_crack.add_argument("--backend", choices=["aircrack", "hashcat", "auto"],
                         default="auto",
                         help="Cracking backend (default: auto-detect)")
    w_crack.add_argument("--timeout", type=int, default=300,
                         help="Max seconds to crack (default: 300)")
    w_crack.add_argument("--dry-run", action="store_true",
                         help="Show commands without cracking")

    w_deauth = wireless_sub.add_parser("deauth",
                                       help="Deauthenticate clients from target APs")
    w_deauth.add_argument("--targets-file", default=None,
                          help="Target selection JSON file (default: most recent)")
    w_deauth.add_argument("--interface", default=None,
                          help="Wireless interface (auto-detect if not specified)")
    w_deauth.add_argument("--count", type=int, default=5,
                          help="Deauth frames per target (default: 5)")
    w_deauth.add_argument("--detect-clients", action="store_true",
                          help="Scan for associated clients before deauth")
    w_deauth.add_argument("--force", action="store_true",
                          help="Skip prompts and proceed")
    w_deauth.add_argument("--output-dir", default=None,
                          help="Output directory (default: outputs/wireless/)")
    w_deauth.add_argument("--dry-run", action="store_true",
                          help="Show deauth plan without executing")

    # ── server ──
    server = subparsers.add_parser("server", help="Manage llama-server")
    server_sub = server.add_subparsers(dest="server_action", help="Server actions")

    # server start
    s_start = server_sub.add_parser("start", help="Start llama-server")
    s_start.add_argument(
        "--model",
        default=None,
        help=f"Model ID (default: {PHASE_DEFAULTS['recon']})",
    )
    s_start.add_argument("--port", type=int, default=8080, help="Port (default: 8080)")
    s_start.add_argument("--host", default="127.0.0.1", help="Host (default: 127.0.0.1)")
    s_start.add_argument(
        "--ngl", type=int, default=-1,
        help="GPU layers (-1 = all, default: -1)",
    )
    s_start.add_argument(
        "--offload-all", action="store_true",
        help="Offload all layers to GPU (same as --ngl -1)",
    )

    # server stop
    server_sub.add_parser("stop", help="Stop llama-server")

    # server restart
    s_restart = server_sub.add_parser("restart", help="Restart llama-server")
    s_restart.add_argument(
        "--model",
        default=None,
        help=f"Model ID (default: keep current or {PHASE_DEFAULTS['recon']})",
    )
    s_restart.add_argument("--port", type=int, default=8080, help="Port")
    s_restart.add_argument("--host", default="127.0.0.1", help="Host")
    s_restart.add_argument("--ngl", type=int, default=-1, help="GPU layers")
    s_restart.add_argument(
        "--offload-all", action="store_true",
        help="Offload all layers to GPU (same as --ngl -1)",
    )

    # server status / models
    server_sub.add_parser("status", help="Check server status")
    server_sub.add_parser("models", help="List available models")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    # ── Server commands ──
    if args.command == "server":
        if not args.server_action:
            parser.print_help()
            sys.exit(1)

        if args.server_action == "start":
            cmd_server_start(args)
        elif args.server_action == "stop":
            cmd_server_stop()
        elif args.server_action == "restart":
            cmd_server_restart(args)
        elif args.server_action == "status":
            cmd_server_status()
        elif args.server_action == "models":
            cmd_server_models()
        return

    # ── Wireless commands ──
    if args.command == "wireless":
        if not args.wireless_action:
            wireless.print_help()
            sys.exit(1)

        wireless_script = str(PROJECT_ROOT / "scripts" / "wireless_scan.py")
        if args.wireless_action == "scan":
            cmd = [sys.executable, wireless_script]
            if args.duration:
                cmd.extend(["--duration", str(args.duration)])
            if args.band:
                cmd.extend(["--band", args.band])
            if args.interface:
                cmd.extend(["--interface", args.interface])
            if args.dry_run:
                cmd.append("--dry-run")
            if args.force:
                cmd.append("--force")
            script_result = subprocess.run(cmd, timeout=120)
            sys.exit(script_result.returncode)
        elif args.wireless_action == "select":
            select_script = str(PROJECT_ROOT / "scripts" / "wireless_select.py")
            cmd = [sys.executable, select_script]
            if getattr(args, "scan_file", None):
                cmd.extend(["--scan-file", args.scan_file])
            if getattr(args, "file", None):
                cmd.extend(["--scan-file", args.file])
            if getattr(args, "auto", False):
                cmd.append("--auto")
            if getattr(args, "max", None):
                cmd.extend(["--max", str(args.max)])
            if getattr(args, "force", False):
                cmd.append("--force")
            script_result = subprocess.run(cmd, timeout=120)
            sys.exit(script_result.returncode)
        elif args.wireless_action == "assess":
            assess_script = str(PROJECT_ROOT / "scripts" / "wireless_assess.py")
            cmd = [sys.executable, assess_script]
            if getattr(args, "targets_file", None):
                cmd.extend(["--targets-file", args.targets_file])
            if getattr(args, "file", None):
                cmd.extend(["--targets-file", args.file])
            if getattr(args, "interface", None):
                cmd.extend(["--interface", args.interface])
            if getattr(args, "no_scan", False):
                cmd.append("--no-scan")
            script_result = subprocess.run(cmd, timeout=120)
            sys.exit(script_result.returncode)
        elif args.wireless_action == "capture":
            capture_script = str(PROJECT_ROOT / "scripts" / "wireless_capture.py")
            cmd = [sys.executable, capture_script]
            if getattr(args, "targets_file", None):
                cmd.extend(["--targets-file", args.targets_file])
            if getattr(args, "file", None):
                cmd.extend(["--targets-file", args.file])
            if getattr(args, "interface", None):
                cmd.extend(["--interface", args.interface])
            if getattr(args, "duration", 60) != 60:
                cmd.extend(["--duration", str(args.duration)])
            if getattr(args, "dry_run", False):
                cmd.append("--dry-run")
            if getattr(args, "force", False):
                cmd.append("--force")
            script_result = subprocess.run(cmd, timeout=max(args.duration + 30, 180))
            sys.exit(script_result.returncode)
        elif args.wireless_action == "crack":
            crack_script = str(PROJECT_ROOT / "scripts" / "wireless_crack.py")
            cmd = [sys.executable, crack_script]
            if getattr(args, "cap", None):
                cmd.extend(["--cap", args.cap])
            if getattr(args, "wordlist", None):
                cmd.extend(["--wordlist", args.wordlist])
            if getattr(args, "backend", "auto") != "auto":
                cmd.extend(["--backend", args.backend])
            if getattr(args, "timeout", 300) != 300:
                cmd.extend(["--timeout", str(args.timeout)])
            if getattr(args, "dry_run", False):
                cmd.append("--dry-run")
            script_result = subprocess.run(cmd, timeout=300)
            sys.exit(script_result.returncode)
        elif args.wireless_action == "deauth":
            deauth_script = str(PROJECT_ROOT / "scripts" / "wireless_deauth.py")
            cmd = [sys.executable, deauth_script]
            if getattr(args, "targets_file", None):
                cmd.extend(["--targets-file", args.targets_file])
            if getattr(args, "interface", None):
                cmd.extend(["--interface", args.interface])
            if getattr(args, "count", 5) != 5:
                cmd.extend(["--count", str(args.count)])
            if getattr(args, "detect_clients", False):
                cmd.append("--detect-clients")
            if getattr(args, "force", False):
                cmd.append("--force")
            if getattr(args, "output_dir", None):
                cmd.extend(["--output-dir", args.output_dir])
            if getattr(args, "dry_run", False):
                cmd.append("--dry-run")
            script_result = subprocess.run(cmd, timeout=120)
            sys.exit(script_result.returncode)
        return

    # ── Scan ──
    # ── Deprecation warning for --wireless ──
    if args.command == "scan" and getattr(args, "wireless", False):
        warn("--wireless is deprecated. Use 'portshim wireless scan' instead.")
        print("  The --wireless flag no longer enables wireless scanning.")
        print("  Wireless is now a separate engagement type:")
        print(f"    {CYAN}portshim wireless scan{RESET}    # Discover APs")
        print(f"    {CYAN}portshim wireless select{RESET}  # Select targets")
        print(f"    {CYAN}portshim wireless assess{RESET}  # Attack selected targets")
        print()
    # ── Banner ──
    print(f"\n{BOLD}{RED}♦ {RESET}{BOLD}PORTSHIM{RESET} {RED}♦{RESET}")
    print(f"{CYAN}On-Site Security Assessment Pipeline{RESET}\n")

    # ── Subnet check ──
    subnet_ok = verify_target_subnet(args.target)
    if not subnet_ok and not args.dry_run:
        # In live mode, require --force to proceed with mismatched subnet
        if not getattr(args, "force", False):
            print(f"  {YELLOW}Pass --force to proceed anyway.{RESET}")
            sys.exit(1)

    # ── Dry run ──
    if args.dry_run:
        print(f"{YELLOW}[DRY RUN] — no changes will be made{RESET}\n")
        print(f"  Would configure: target={args.target}, engagement={args.engagement}, mode={args.mode}")
        print(f"  Would sync knowledge: {not args.no_freshness_check}")
        print(f"  Models dir: {args.models_dir or 'default'}")
        if args.mode in ("local", "hybrid") and not args.no_server:
            model = PHASE_DEFAULTS["recon"]
            print(f"  Would start llama-server: {model} on 127.0.0.1:8080")
        print()
        show_hermes_instructions(args.target, args.engagement, args.mode, args.wireless)
        return

    # ── Execute ──
    if not check_prerequisites():
        print(f"\n{RED}Prerequisites missing. Run 'python deploy.py' first.{RESET}")
        sys.exit(1)

    # Auto-start server for local/hybrid modes
    if args.mode in ("local", "hybrid") and not args.no_server:
        model = PHASE_DEFAULTS["recon"]
        if server_running():
            current = server_get_model()
            if current != model:
                warn(f"Server running with different model ({current}). Restarting...")
                server_stop()
                print()
                server_start(model_id=model)
            else:
                status(f"llama-server already running with {model}", True)
        else:
            server_start(model_id=model)

    sync_knowledge()

    if not args.no_freshness_check:
        check_freshness()

    if not configure_engagement(args.engagement):
        sys.exit(1)

    if not configure_llm(args.mode, args.models_dir):
        sys.exit(1)

    show_hermes_instructions(args.target, args.engagement, args.mode, args.wireless)


if __name__ == "__main__":
    main()
